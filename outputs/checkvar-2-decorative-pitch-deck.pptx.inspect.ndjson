{"kind":"textbox","id":"sh/mhsry18b","slide":5,"name":"text","text":"Exact, durable signals connect cases to campaigns.","textPreview":"Exact, durable signals connect cases to campaigns.","textChars":50,"textLines":1,"bbox":[62,358,390,65]}
