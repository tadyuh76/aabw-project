{"kind":"textbox","id":"sh/i9ojy90z","slide":1,"name":"text","text":"Two minutes\nto decide.","textPreview":"Two minutes | to decide.","textChars":22,"textLines":2,"bbox":[58,158,520,150]}
{"kind":"textbox","id":"sh/5cf294ja","slide":1,"name":"text","text":"Real—or a transfer away from loss?","textPreview":"Real—or a transfer away from loss?","textChars":34,"textLines":1,"bbox":[62,340,500,62]}
