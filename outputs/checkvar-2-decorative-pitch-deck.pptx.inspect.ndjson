{"kind":"textbox","id":"sh/b6psnaxs","slide":4,"name":"text","text":"Not just a warning.\nAn explanation.","textPreview":"Not just a warning. | An explanation.","textChars":35,"textLines":2,"bbox":[58,118,500,118]}
