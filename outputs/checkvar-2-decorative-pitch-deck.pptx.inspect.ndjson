{"kind":"textbox","id":"sh/wjelcr2x","slide":6,"name":"text","text":"Review 2 beneficiary accounts","textPreview":"Review 2 beneficiary accounts","textChars":29,"textLines":1,"bbox":[62,332,430,34]}
{"kind":"textbox","id":"sh/7e5kfmlg","slide":6,"name":"text","text":"Escalate the active domain","textPreview":"Escalate the active domain","textChars":26,"textLines":1,"bbox":[62,390,430,34]}
